# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/

# Generated PrestaShop API clients (regenerate: python scripts/generate_prestashop_clients.py)
simulator/generated/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment variables (real/local values only — committed defaults use *.default.env)
.env
.env.*

# Distribution / build
dist/
build/

# Docker volume data (runtime, not source)
workspaces/*/volumes/

# The public workspace is the production deployment config (real domains, secrets,
# TLS wiring) — kept out of this open-source repo, unlike the local `default` one.
workspaces/public/
