# ─────────────────────────────────────────────────────────────────────────────
# Activity database (PostgreSQL) — DEMO template.
#
# Split out from default.env so ONLY the DB-facing services load it: the
# `simulatordb` container reads the POSTGRES_* keys, and the `portal` reads
# SIMULATORDB_URL. Neither needs the simulator's PrestaShop/Redis secrets, which
# stay in default.env. The simulator app loads BOTH files.
#
# The password in SIMULATORDB_URL MUST match POSTGRES_PASSWORD. SIMULATORDB_URL
# uses the in-container hostname; a LOCAL app run instead uses the localhost DSN
# default in simulator/src/config.py. Bring the DB up and run
# `uv run alembic upgrade head` before starting the simulator.
#
#   ⚠️  DEMO ONLY — never reuse these credentials in a real deployment.
# ─────────────────────────────────────────────────────────────────────────────
SIMULATORDB_URL=postgresql+psycopg://simulator:changeme_demo@simulatordb:5432/simulator
POSTGRES_DB=simulator
POSTGRES_USER=simulator
POSTGRES_PASSWORD=changeme_demo
