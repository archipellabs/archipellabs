# ─────────────────────────────────────────────────────────────────────────────
# Simulator container configuration — DEMO template.
#
# This committed file holds working demo values so the simulator runs out of the
# box. docker-compose-simulator.yaml loads it, then loads an optional (gitignored)
# `.env` in the same folder for local overrides. To customise, either edit a
# `.env` copy or export the vars in your shell.
#
#   ⚠️  DEMO ONLY — the secrets below match config/prestashop/default.env and protect
#       nothing real. Never reuse them in a real deployment.
# ─────────────────────────────────────────────────────────────────────────────

# --- runtime (Redis) ---
REDIS_URL=redis://redis:6379/0

# --- activity database (PostgreSQL) ---
# One env file for the whole stack: the `simulatordb` container
# (docker-compose-simulator.yaml) reads the POSTGRES_* keys; the simulator app
# reads SIMULATORDB_URL. The password in SIMULATORDB_URL MUST match
# POSTGRES_PASSWORD below. SIMULATORDB_URL uses the in-container hostname; a LOCAL
# app run instead uses the localhost DSN default in src/config.py. Bring the DB up
# and run `uv run alembic upgrade head` before starting the simulator.
#
#   ⚠️  DEMO ONLY — never reuse these credentials in a real deployment.
SIMULATORDB_URL=postgresql+psycopg://simulator:changeme_demo@simulatordb:5432/simulator
POSTGRES_DB=simulator
POSTGRES_USER=simulator
POSTGRES_PASSWORD=changeme_demo

# --- PrestaShop Webservice API (catalog + stock flows, Basic auth) ---
# MUST match WEBSERVICE_API_KEY in config/prestashop/default.env (the sidecar creates
# the key with that value; the simulator authenticates with it).
PRESTASHOP_WEBSERVICE_URL=https://gateway/api
PRESTASHOP_WEBSERVICE_API_KEY=5ZXDKB5NJZL1LL69VNUSWAP7D6ZSEK7C

# --- PrestaShop Admin API (OAuth2) ---
# MUST match API_CLIENT_ID / API_CLIENT_SECRET in config/prestashop/default.env.
PRESTASHOP_BASE_URL=https://gateway/admin-api
PRESTASHOP_CLIENT_ID=root_admin_integration
PRESTASHOP_CLIENT_SECRET=947129378d6e912e165787c975e8af45c08b11296c884090b8b75a7256c6d7df

# --- shop front-end (browser simulation) ---
SHOP_BASE_URL=https://gateway

# --- browser (containers need Chromium's --no-sandbox) ---
HEADLESS=true
BROWSER_NO_SANDBOX=true

# --- flow kill-switches ---
CATALOG_ENABLED=true
JOURNEY_ENABLED=false
ARRIVALS_ENABLED=false
