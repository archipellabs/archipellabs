# ─────────────────────────────────────────────────────────────────────────────
# Matomo tracking stack — DEMO credentials.
#
#   ⚠️  DEMO ONLY. Committed so the tracking stack runs out of the box on a
#       developer machine. They protect nothing real. Never reuse them in an
#       internet-facing deployment — generate fresh secrets there.
#
# docker-compose-tracking.yaml injects this into every Matomo service via
# `env_file`; MariaDB reads the MYSQL_* keys, the Matomo app + archiver read the
# MATOMO_DATABASE_* keys. Each service ignores the keys it does not understand.
# ─────────────────────────────────────────────────────────────────────────────

# --- MariaDB (matomodb) ---
MYSQL_ROOT_PASSWORD=matomo_root
MYSQL_DATABASE=matomo
MYSQL_USER=matomo
MYSQL_PASSWORD=matomo

# --- Matomo app + archiver (matomo, matomo-cron) ---
# DB connection consumed by the app and by the headless installer (matomo-sidecar).
MATOMO_DATABASE_HOST=matomodb
MATOMO_DATABASE_USERNAME=matomo
MATOMO_DATABASE_PASSWORD=matomo
MATOMO_DATABASE_DBNAME=matomo

# --- Matomo headless bootstrap (matomo-sidecar) — DEMO super user + first site ---
MATOMO_ADMIN_LOGIN=admin
MATOMO_ADMIN_PASSWORD=matomo_demo_admin
MATOMO_ADMIN_EMAIL=admin@timberworks.test
MATOMO_SITE_NAME=TimberWorks
MATOMO_SITE_URL=https://localhost/
