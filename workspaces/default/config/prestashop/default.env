# ─────────────────────────────────────────────────────────────────────────────
# TimberWorks — e-commerce stack: config + DEMO secrets (prestashopdb, prestashop,
# prestashop-sidecar). One committed env_file per stack, like config/matomo/default.env.
#
#   ⚠️  DEMO ONLY. The credentials below are committed on purpose so the lab runs
#       out of the box (localhost, self-signed TLS). They protect nothing real —
#       never reuse them in an internet-facing deployment; generate fresh secrets
#       there and keep them out of git.
#
# docker-compose-ecommerce.yaml loads this into every service of the stack via
# `env_file`; each reads only the keys it understands. (PrestaShop's own web-root
# .env — feature flags / trusted proxies — is the separate webroot.env, not this.)
# ─────────────────────────────────────────────────────────────────────────────

# --- MySQL (prestashopdb) ---
MYSQL_ROOT_PASSWORD=admin
MYSQL_DATABASE=prestashop

# --- PrestaShop → MySQL connection (prestashop) ---
# PrestaShop connects as root, so DB_PASSWD must equal MYSQL_ROOT_PASSWORD.
DB_SERVER=prestashopdb
DB_NAME=prestashop
DB_USER=root
DB_PASSWD=admin

# --- PrestaShop install / runtime (prestashop) ---
PS_INSTALL_AUTO=1
PS_DOMAIN=localhost
PS_ENABLE_SSL=1
PS_FOLDER_ADMIN=admin-dev
PS_FOLDER_INSTALL=install-dev
# Optional dev toggles — uncomment to enable:
#PS_DEV_MODE=0
#PS_HOST_MODE=0
#PS_DEMO_MODE=0

# --- PrestaShop back-office admin login (prestashop) ---
# The admin account the installer creates. Log in at https://localhost/admin-dev.
ADMIN_MAIL=admin@timberworks.test
ADMIN_PASSWD=sdoisdovoinsdvoisdvoisdhf

# --- Admin API OAuth2 client (sidecar creates it → simulator authenticates) ---
# CreateAdminApiClient registers this client; the simulator authenticates with the
# SAME id + secret. Mirror into simulator/default.env (PRESTASHOP_CLIENT_*).
API_CLIENT_ID=root_admin_integration
API_CLIENT_SECRET=947129378d6e912e165787c975e8af45c08b11296c884090b8b75a7256c6d7df

# --- Webservice API key (sidecar creates it → simulator uses it) ---
# ConfigureWebservice provisions this key; the simulator's catalog/stock flows use
# it. Mirror into simulator/default.env (PRESTASHOP_WEBSERVICE_API_KEY).
WEBSERVICE_API_KEY=5ZXDKB5NJZL1LL69VNUSWAP7D6ZSEK7C

# --- Matomo tracking integration (prestashop-sidecar InstallMatomo step) ---
# Browser-reachable HTTPS URL of Matomo (the gateway's /stats/ path) + the site id
# created by the matomo-sidecar. Configures the tec_matomo module on the shop.
MATOMO_URL=https://localhost/stats/
MATOMO_SITE_ID=1
